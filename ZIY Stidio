        .nav-inner {
            max-width: 1280px; margin: 0 auto; padding: 12px 24px;
            display: flex; align-items: center; justify-content: space-between; position: relative; z-index: 2;
        }
        .logo {
            font-weight: 600; font-size: 1.4rem; letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1d1d1f 0%, #434349 100%);
            background-clip: text; -webkit-background-clip: text; color: transparent;
        }
        .nav-icons { display: flex; gap: 24px; align-items: center; position: relative; }
        .nav-icons i {
            font-size: 1.3rem; cursor: pointer; color: #1d1d1f;
            transition: transform 0.3s cubic-bezier(0.3, 0, 0.2, 1), color 0.3s cubic-bezier(0.3, 0, 0.2, 1), opacity 0.3s cubic-bezier(0.3, 0, 0.2, 1);
            will-change: transform;
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
            z-index: 10;
            position: relative;
        }
        .nav-icons i:hover { color: #333; transform: scale(1.06); }
        .nav-icons i:active { transform: scale(0.94); color: #0071e3; transition: transform 0.1s cubic-bezier(0.2, 0.9, 0.4, 1); }
        #searchIcon, #userIconBtn {
            display: inline-block !important;
            visibility: visible !important;
            opacity: 1 !important;
            pointer-events: auto !important;
            z-index: 20;
        }
        .menu-icon {
            display: flex; flex-direction: column; justify-content: space-between;
            width: 24px; height: 18px; cursor: pointer; position: relative; z-index: 10;
            transition: transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
            will-change: transform;
        }
        .menu-icon:hover { transform: scale(1.04); }
        .menu-icon:active { transform: scale(0.92); transition: transform 0.1s cubic-bezier(0.2, 0.9, 0.4, 1); }
        .menu-icon span {
            display: block; width: 100%; height: 2px; background-color: #1d1d1f; border-radius: 2px;
            transition: transform 0.3s cubic-bezier(0.3, 0, 0.2, 1), opacity 0.2s cubic-bezier(0.3, 0, 0.2, 1), background-color 0.2s;
            transform-origin: center;
        }
        .menu-icon:hover span { background-color: #333; }
        .menu-icon:active span { background-color: #0071e3; }
        .menu-icon.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
        .menu-icon.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
        .menu-icon.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

        .search-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.3); backdrop-filter: blur(8px); z-index: 998;
            opacity: 0; visibility: hidden; transition: opacity 0.35s cubic-bezier(0.3, 0, 0.2, 1), visibility 0.35s;
        }
        .search-overlay.active { opacity: 1; visibility: visible; }
        .search-dropdown {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(245, 245, 247, 0.95); backdrop-filter: blur(40px);
            z-index: 999; padding: 80px 28px 40px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.1); border-bottom: 1px solid rgba(255,255,255,0.3);
            transform: translateY(-100%) scale(0.96);
            opacity: 0;
            transition: transform 0.35s cubic-bezier(0.3, 0, 0.2, 1), opacity 0.35s cubic-bezier(0.3, 0, 0.2, 1);
            pointer-events: none;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }
        .search-dropdown.active { transform: translateY(0) scale(1); opacity: 1; pointer-events: auto; }
        .search-dropdown .close-search-full {
            position: absolute; top: 24px; right: 24px; font-size: 2rem;
            color: #1d1d1f; cursor: pointer; z-index: 1000;
            transition: transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
        }
        .search-dropdown .close-search-full:hover { transform: scale(1.1) rotate(90deg); }
        .search-dropdown .close-search-full:active { transform: scale(0.9); }
        .search-header {
            padding: 0 0 12px;
            border-bottom: 1px solid rgba(0,0,0,0.1);
            margin-bottom: 16px;
        }
        .search-input-wrapper {
            display: flex; align-items: center;
            background: rgba(255,255,255,0.5); backdrop-filter: blur(10px);
            border-radius: 40px; padding: 4px 16px;
            border: 1px solid rgba(0,0,0,0.08);
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .search-input-wrapper:focus-within {
            border-color: #0071e3; box-shadow: 0 0 0 3px rgba(0,113,227,0.15);
        }
        .search-input-wrapper i { color: #86868b; font-size: 1rem; margin-right: 8px; }
        .search-input {
            width: 100%; padding: 14px 0; border: none; background: transparent;
            font-size: 1.2rem; outline: none; color: #1d1d1f;
            font-family: 'SF Pro Display', 'SF Pro Text', -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
            font-weight: 500;
        }
        .search-input::placeholder { color: #86868b; font-weight: 400; }
        .search-content {
            padding: 8px 0 16px;
            overflow-y: auto;
            flex: 1;
        }
        .search-section-title {
            padding: 12px 0 8px; font-size: 0.9rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 0.5px; color: #86868b;
        }
        .search-result-item {
            padding: 16px 0; cursor: pointer;
            transition: background 0.15s, transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .search-result-item:hover { background: rgba(0,0,0,0.02); transform: translateX(4px); }
        .search-result-item:active { transform: scale(0.98); background: rgba(0,0,0,0.04); transition: transform 0.1s; }
        .result-title {
            font-weight: 600; margin-bottom: 4px; color: #1d1d1f;
            font-size: 1.2rem; font-family: 'SF Pro Display', 'SF Pro Text', -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
            font-weight: 500;
        }
        .result-meta { font-size: 0.8rem; color: #86868b; }
        .hot-tag {
            display: inline-block; padding: 8px 18px; background: rgba(0,0,0,0.05);
            border-radius: 30px; font-size: 0.95rem; margin: 4px 8px 4px 0;
            cursor: pointer; transition: background 0.2s, transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
            color: #1d1d1f; font-weight: 500;
        }
        .hot-tag:hover { background: rgba(0,0,0,0.1); transform: scale(1.05); }
        .hot-tag:active { transform: scale(0.95); background: rgba(0,0,0,0.15); transition: transform 0.1s; }
        .user-menu {
            position: absolute; top: 48px; right: 0; background: rgba(255,255,255,0.95); backdrop-filter: blur(40px);
            border-radius: 28px; box-shadow: 0 12px 30px rgba(0,0,0,0.1), 0 0 0 1px rgba(255,255,255,0.3);
            padding: 12px 0; min-width: 180px; z-index: 150; opacity: 0; visibility: hidden;
            transform: scale(0.96) translateY(-8px);
            transition: opacity 0.35s cubic-bezier(0.3, 0, 0.2, 1), transform 0.35s cubic-bezier(0.3, 0, 0.2, 1), visibility 0.35s;
        }
        .user-menu.active { opacity: 1; visibility: visible; transform: scale(1) translateY(0); }
        .user-menu a {
            display: block; padding: 12px 20px; color: #1d1d1f; text-decoration: none; font-size: 0.95rem; font-weight: 500;
            transition: background 0.2s, transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
        }
        .user-menu a:hover { background: rgba(0,0,0,0.04); transform: translateX(4px); }
        .user-menu a:active { transform: scale(0.97); background: rgba(0,0,0,0.06); transition: transform 0.1s; }
        .mobile-menu {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(245, 245, 247, 0.95); backdrop-filter: blur(40px);
            z-index: 200; padding: 80px 28px 40px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.1); border-bottom: 1px solid rgba(255,255,255,0.3);
            transform: translateY(-100%) scale(0.96);
            opacity: 0;
            transition: transform 0.35s cubic-bezier(0.3, 0, 0.2, 1), opacity 0.35s cubic-bezier(0.3, 0, 0.2, 1);
            pointer-events: none;
            overflow-y: auto;
        }
        .mobile-menu.active { transform: translateY(0) scale(1); opacity: 1; pointer-events: auto; }
        .mobile-menu a {
            display: block; font-size: 1.5rem; font-weight: 500; padding: 16px 0;
            color: #1d1d1f; text-decoration: none; border-bottom: 1px solid rgba(0,0,0,0.05);
            font-family: 'SF Pro Display', 'SF Pro Text', -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
            text-align: left; width: 100%;
            transition: color 0.2s, transform 0.3s cubic-bezier(0.3, 0, 0.2, 1), padding-left 0.3s cubic-bezier(0.3, 0, 0.2, 1);
        }
        .mobile-menu a:hover { color: #0071e3; padding-left: 8px; }
        .mobile-menu a:active { transform: scale(0.98); transition: transform 0.1s; }
        .mobile-menu a:last-child { border-bottom: none; }
        .close-menu {
            position: absolute; top: 24px; right: 24px; font-size: 2rem;
            cursor: pointer; color: #1d1d1f; z-index: 210;
            transition: transform 0.3s cubic-bezier(0.3, 0, 0.2, 1);
        }
        .close-menu:hover { transform: rotate(90deg); }
        .close-menu:active { transform: scale(0.9); transition: transform 0.1s; }
        .menu-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.2); backdrop-filter: blur(4px);
            z-index: 199; opacity: 0; visibility: hidden; transition: opacity 0.35s cubic-bezier(0.3, 0, 0.2, 1), visibility 0.35s;
        }
        .menu-overlay.active { opacity: 1; visibility: visible; }
        /* 顶部横幅 - 深色渐变循环动画，超长周期，颜色更鲜艳 */
        .top-banner {
            padding-top: 70px;
            text-align: center;
            background: linear-gradient(90deg, #6a0e0e, #8B1A2B, #6A2E6A, #1a2a5a, #0d2b4a, #0a3a2a);
            background-size: 300% 300%;
            color: #fff;
            padding: 140px 24px 70px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            position: relative;
            overflow: hidden;
            animation: bannerGradient 60s ease-in-out infinite alternate;
        }
        @keyframes bannerGradient {
            0% { background-position: 0% 0%; }
            10% { background-position: 80% 20%; }
            20% { background-position: 20% 90%; }
            30% { background-position: 100% 30%; }
            40% { background-position: 10% 70%; }
            50% { background-position: 60% 100%; }
            60% { background-position: 90% 10%; }
            70% { background-position: 30% 50%; }
            80% { background-position: 70% 80%; }
            90% { background-position: 40% 30%; }
            100% { background-position: 0% 0%; }
        }
        .top-banner::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(ellipse at 20% 30%, rgba(139,26,43,0.5) 0%, transparent 50%),
                        radial-gradient(ellipse at 60% 40%, rgba(106,46,106,0.4) 0%, transparent 45%),
                        radial-gradient(ellipse at 80% 60%, rgba(26,42,90,0.5) 0%, transparent 50%),
                        radial-gradient(ellipse at 90% 80%, rgba(13,43,74,0.3) 0%, transparent 40%),
                        radial-gradient(ellipse at 70% 90%, rgba(10,58,42,0.2) 0%, transparent 40%);
            pointer-events: none;
        }
        .top-banner .banner-content {
            position: relative;
            z-index: 1;
        }
        .top-banner .banner-title {
            font-size: 5.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #f5f5f7, #d0d0d5);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            margin-bottom: 16px;
            text-shadow: 0 2px 30px rgba(0,0,0,0.3);
        }
        .top-banner .banner-sub {
            font-size: 2.8rem;
            font-weight: 400;
            color: #f0f0f2;
            margin-bottom: 20px;
            letter-spacing: 2px;
            text-shadow: 0 2px 20px rgba(0,0,0,0.4);
        }
        .top-banner .banner-meta {
            font-size: 1.2rem;
            color: #c0c0c5;
            font-weight: 300;
            letter-spacing: 1px;
        }
        .top-banner .banner-meta i {
            margin-right: 8px;
        }
        main { padding-top: 0; }
        .module {
            padding: 70px 0 80px; margin-bottom: 40px; border-radius: 48px; backdrop-filter: blur(4px);
            text-align: center; scroll-margin-top: 80px;
        }
        .module-dark { background: rgba(0,0,0,0.85); color: #fff; }
        .module-light { background: rgba(255,255,255,0.9); color: #1d1d1f; }
        .module-dark .module-title, .module-dark .module-sub { color: #fff; }
        .module-dark .module-sub { color: #e0e0e6; }
        .animate-group { opacity: 0; }
        .animate-group.animated { opacity: 1; }
        .animate-group .module-title,
        .animate-group .module-sub,
        .animate-group .btn-group,
        .animate-group .module-visual,
        .animate-group .data-source {
            opacity: 0; transform: translateY(36px);
            transition: opacity 0.8s cubic-bezier(0.3, 0, 0.2, 1), transform 0.8s cubic-bezier(0.3, 0, 0.2, 1);
            transition-delay: 0s;
        }
        .animate-group.animated .module-title { opacity: 1; transform: translateY(0); transition-delay: 0s; }
        .animate-group.animated .module-sub { opacity: 1; transform: translateY(0); transition-delay: 0.15s; }
        .animate-group.animated .btn-group { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }
        .animate-group.animated .module-visual { opacity: 1; transform: translateY(0); transition-delay: 0.45s; }
        .animate-group.animated .data-source { opacity: 1; transform: translateY(0); transition-delay: 0.6s; }
        .community-preview .animate-group .community-header,
        .community-preview .animate-group .community-grid,
        .community-preview .animate-group > div:last-child {
            opacity: 0; transform: translateY(36px);
            transition: opacity 0.8s cubic-bezier(0.3, 0, 0.2, 1), transform 0.8s cubic-bezier(0.3, 0, 0.2, 1);
        }
        .community-preview .animate-group.animated .community-header { opacity: 1; transform: translateY(0); transition-delay: 0s; }
        .community-preview .animate-group.animated .community-grid { opacity: 1; transform: translateY(0); transition-delay: 0.15s; }
        .community-preview .animate-group.animated > div:last-child { opacity: 1; transform: translateY(0); transition-delay: 0.3s; }
        .module-title { font-size: 2.6rem; font-weight: 600; margin-bottom: 12px; }
        .module-sub { font-size: 1.2rem; font-weight: 400; max-width: 600px; margin: 0 auto 16px; }
        .btn-group { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 16px; }
        .btn-primary, .btn-secondary {
            padding: 10px 24px; border-radius: 980px; font-weight: 600; font-size: 0.95rem;
            transition: all 0.35s cubic-bezier(0.3, 0, 0.2, 1);
            cursor: pointer; border: none;
            will-change: transform;
        }
        .btn-primary { background-color: #0071e3; color: white; box-shadow: 0 2px 8px rgba(0,113,227,0.2); }
        .btn-primary:hover { transform: scale(1.04); background-color: #0077ed; box-shadow: 0 6px 16px rgba(0,113,227,0.35); }
