    <style>
        /* 完全保留所有样式，仅新增主题切换按钮样式，去掉图片相关背景 */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display', 'Inter', sans-serif;
            background: #f5f5f7; color: #1d1d1f; line-height: 1.42857;
            scroll-behavior: smooth; -webkit-tap-highlight-color: transparent;
            transition: background 0.3s cubic-bezier(0.3, 0, 0.2, 1), color 0.3s cubic-bezier(0.3, 0, 0.2, 1);
        }
        /* 移除所有图片背景 */
        .map-placeholder { background: none !important; background-color: #2a1f33; }
        .typhoon-satellite { background: linear-gradient(145deg, #1a0a1f, #0d0d1a); }
        .module-visual { background: rgba(255,255,255,0.05); }
        .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(30px) saturate(180%) brightness(1.1);
            -webkit-backdrop-filter: blur(30px) saturate(180%) brightness(1.1);
            border-bottom: 0.5px solid rgba(255, 255, 255, 0.2);
            overflow: hidden;
            transition: background 0.3s cubic-bezier(0.3, 0, 0.2, 1);
            box-shadow: 
                inset 0 1px 0 rgba(255, 255, 255, 0.4),
                0 8px 32px rgba(0, 0, 0, 0.08);
            border: 0.5px solid rgba(255, 255, 255, 0.15);
            border-top: none;
        }
        .navbar::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -20%;
            width: 140%;
            height: 200%;
            background: 
                radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(200,220,255,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.05) 0%, transparent 70%);
            filter: blur(40px);
            mix-blend-mode: overlay;
            pointer-events: none;
            animation: liquidShimmer 8s ease-in-out infinite alternate;
        }
        @keyframes liquidShimmer {
            0% { transform: translateX(-5%) translateY(-5%) rotate(-2deg) scale(1); opacity: 0.6; }
            50% { transform: translateX(5%) translateY(3%) rotate(1deg) scale(1.05); opacity: 0.9; }
            100% { transform: translateX(-3%) translateY(-2%) rotate(-1deg) scale(0.98); opacity: 0.7; }
        }
        .navbar::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, 
                rgba(255,255,255,0) 0%, 
                rgba(255,255,255,0.5) 20%, 
                rgba(255,255,255,0.8) 50%, 
                rgba(255,255,255,0.5) 80%, 
                rgba(255,255,255,0) 100%);
            pointer-events: none;
        }
        .navbar .nav-inner {
            position: relative;
            z-index: 2;
        }
        .navbar .nav-inner::before {
            content: '';
            position: absolute;
            top: -20px;
            left: 10%;
            width: 80%;
            height: 60px;
            background: radial-gradient(ellipse at center, rgba(255,255,255,0.12) 0%, transparent 70%);
            filter: blur(20px);
            pointer-events: none;
            animation: glowFloat 6s ease-in-out infinite alternate;
        }
        @keyframes glowFloat {
            0% { transform: translateY(0) scale(1); opacity: 0.5; }
            100% { transform: translateY(-5px) scale(1.1); opacity: 0.8; }
        }

        body:not(.light-mode) .navbar {
            background: rgba(20, 20, 22, 0.35);
            backdrop-filter: blur(30px) saturate(180%) brightness(0.9);
            -webkit-backdrop-filter: blur(30px) saturate(180%) brightness(0.9);
            border-bottom-color: rgba(255, 255, 255, 0.08);
            box-shadow: 
                inset 0 1px 0 rgba(255, 255, 255, 0.1),
                0 8px 32px rgba(0, 0, 0, 0.3);
            border-color: rgba(255, 255, 255, 0.06);
        }
        body:not(.light-mode) .navbar::before {
            background: 
                radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.1) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(100,150,255,0.08) 0%, transparent 50%);
        }
        body:not(.light-mode) .navbar::after {
            background: linear-gradient(90deg, 
                rgba(255,255,255,0) 0%, 
                rgba(255,255,255,0.2) 20%, 
                rgba(255,255,255,0.4) 50%, 
                rgba(255,255,255,0.2) 80%, 
                rgba(255,255,255,0) 100%);
        }

        body.light-mode .navbar {
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(30px) saturate(180%) brightness(1.1);
            -webkit-backdrop-filter: blur(30px) saturate(180%) brightness(1.1);
            border-bottom-color: rgba(255, 255, 255, 0.2);
            box-shadow: 
                inset 0 1px 0 rgba(255, 255, 255, 0.4),
                0 8px 32px rgba(0, 0, 0, 0.08);
            border-color: rgba(255, 255, 255, 0.15);
        }
        body.light-mode .navbar::before {
            background: 
                radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 80%, rgba(200,220,255,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(255,255,255,0.05) 0%, transparent 70%);
