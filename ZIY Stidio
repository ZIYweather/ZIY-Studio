        // 主题切换逻辑 - 与语言切换交互逻辑一致
        const themeTrigger = document.getElementById('themeToggleBtn');
        const themeDropdown = document.getElementById('themeDropdown');
        const themeCurrentText = document.getElementById('themeCurrentText');
        const themeItems = document.querySelectorAll('#themeDropdown span');
        const body = document.body;

        // 检测系统主题
        function getSystemTheme() {
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }

        // 应用主题
        function applyTheme(theme) {
            body.classList.remove('light-mode', 'dark-mode');
            themeItems.forEach(item => item.classList.remove('active'));

            const themeNames = { light: '☀️ 浅色', dark: '🌙 深色', auto: '⚙️ 自动' };
            if (themeCurrentText) {
                themeCurrentText.textContent = themeNames[theme] || '浅色';
            }

